<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controllers.LoginController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>controllers.LogoutController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SearchController</servlet-name>
        <servlet-class>controllers.SearchController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CreateBookingController</servlet-name>
        <servlet-class>controllers.CreateBookingController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GetRoomController</servlet-name>
        <servlet-class>controllers.GetRoomController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CancelBookingController</servlet-name>
        <servlet-class>controllers.CancelBookingController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CheckInOutController</servlet-name>
        <servlet-class>controllers.CheckInOutController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UpdateBookingController</servlet-name>
        <servlet-class>controllers.UpdateBookingController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/LoginController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/LogoutController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SearchController</servlet-name>
        <url-pattern>/SearchController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CreateBookingController</servlet-name>
        <url-pattern>/CreateBookingController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GetRoomController</servlet-name>
        <url-pattern>/GetRoomController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CancelBookingController</servlet-name>
        <url-pattern>/CancelBookingController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CheckInOutController</servlet-name>
        <url-pattern>/CheckInOutController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateBookingController</servlet-name>
        <url-pattern>/UpdateBookingController</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
